@page "/"
@page "/statistics"
@using Kairos.Application.Services
@using Kairos.Application.Resources
@using System.Globalization
@inject ITimeTrackingService TimeService
@inject IStatisticsService StatisticsService
@inject IStringLocalizer<Strings> Localizer

<div class="statistics-page">
    <div class="page-header">
        <h2 class="page-title">@Localizer["NavStatistics"]</h2>

        <div class="view-toggle">
            <button class="@(CurrentView == ViewMode.Day ? "active" : "")" @onclick="() => SetView(ViewMode.Day)">@Localizer["Today"]</button>
            <button class="@(CurrentView == ViewMode.Week ? "active" : "")" @onclick="() => SetView(ViewMode.Week)">@Localizer["ThisWeek"]</button>
            <button class="@(CurrentView == ViewMode.Month ? "active" : "")" @onclick="() => SetView(ViewMode.Month)">@Localizer["ThisMonth"]</button>
        </div>
    </div>

    <div class="stat-summary-card">
        <div class="stat-label">@Localizer["TotalTrackedTime"]</div>
        <div class="stat-big-value">@((int)TotalTime.TotalHours)<span class="stat-unit">h</span> @(TotalTime.Minutes)<span class="stat-unit">m</span></div>
        <div class="stat-period">(@PeriodLabel)</div>
    </div>

    <!-- Timeline Chart -->
    <div class="chart-container">
        <svg viewBox="0 0 800 400" class="timeline-chart" preserveAspectRatio="xMidYMid meet">
            <!-- Grid lines -->
            <g class="grid-lines">
                @for (int i = 0; i <= 4; i++)
                {
                    var y = 50 + i * 75;
                    <line x1="50" y1="@y" x2="750" y2="@y" stroke="#333" stroke-dasharray="4,4" />
                }
                <!-- Vertical grid lines -->
                @for (int i = 0; i <= 4; i++)
                {
                    var x = 50 + i * 175;
                    <line x1="@x" y1="50" x2="@x" y2="350" stroke="#333" stroke-dasharray="4,4" />
                }
            </g>

            <!-- Y-axis labels -->
            <g class="y-labels">
                @{
                    var range = MaxY - MinY;
                    if (range == 0) range = 1;
                }
                @for (int i = 0; i <= 4; i++)
                {
                    var value = MaxY - (i * range / 4);
                    var y = 50 + i * 75;
                    @((MarkupString)$@"<text x=""45"" y=""{y + 5}"" text-anchor=""end"" fill=""#888"" font-size=""12"">{value.ToString("F1", CultureInfo.InvariantCulture)}h</text>")
                }
            </g>

            <!-- X-axis time labels -->
            <g class="x-labels">
                @{
                    var chartEndTime = EndDate.DateTime;
                    var chartStartTime = StartDate.DateTime;
                    var chartPeriod = chartEndTime - chartStartTime;
                }
                @for (int i = 0; i <= 4; i++)
                {
                    var x = 50 + i * 175; // 700 / 4 = 175
                    var time = chartStartTime + TimeSpan.FromTicks((long)(chartPeriod.Ticks * i / 4.0));
                    var timeLabel = FormatTimeLabel(time);
                    @((MarkupString)$@"<text x=""{x}"" y=""370"" text-anchor=""middle"" fill=""#888"" font-size=""11"">{System.Net.WebUtility.HtmlEncode(timeLabel)}</text>")
                }
            </g>

            <!-- Gradient definitions -->
            <defs>
                @foreach (var color in Segments.Select(s => s.Color).Distinct())
                {
                    var colorId = color.Replace("#", "");
                    <linearGradient id="areaGradient_@colorId" x1="0" x2="0" y1="0" y2="1">
                        <stop offset="0%" stop-color="@color" stop-opacity="0.4" />
                        <stop offset="100%" stop-color="@color" stop-opacity="0" />
                    </linearGradient>
                }
            </defs>

            <!-- Data visualization -->
            @if (Segments.Count > 0)
            {
                @foreach (var segment in Segments)
                {
                    var firstX = GetXFromTimestamp(segment.StartTime);
                    var lastX = GetXFromTimestamp(segment.EndTime);
                    var firstY = GetY(segment.StartBalance);
                    var lastY = GetY(segment.EndBalance);

                    var colorId = segment.Color.Replace("#", "");

                    if (lastX > firstX) // Only draw if the segment has a width
                    {
                        <!-- Area fill -->
                        var areaPath = $"M {firstX.ToString(CultureInfo.InvariantCulture)} {GetY(0).ToString(CultureInfo.InvariantCulture)} " +
                                       $"L {firstX.ToString(CultureInfo.InvariantCulture)} {firstY.ToString(CultureInfo.InvariantCulture)} " +
                                       $"L {lastX.ToString(CultureInfo.InvariantCulture)} {lastY.ToString(CultureInfo.InvariantCulture)} " +
                                       $"L {lastX.ToString(CultureInfo.InvariantCulture)} {GetY(0).ToString(CultureInfo.InvariantCulture)} Z";

                        <path d="@areaPath" fill="url(#areaGradient_@colorId)" opacity="0.3" />

                        <!-- Line -->
                        var linePath = $"M {firstX.ToString(CultureInfo.InvariantCulture)} {firstY.ToString(CultureInfo.InvariantCulture)} " +
                                       $"L {lastX.ToString(CultureInfo.InvariantCulture)} {lastY.ToString(CultureInfo.InvariantCulture)}";

                        <path d="@linePath" fill="none" stroke="@segment.Color" stroke-width="3" />
                    }
                }

                <!-- Current value indicator -->
                var lastSegment = Segments.Last();
                var endX = GetXFromTimestamp(lastSegment.EndTime);
                var endY = GetY(lastSegment.EndBalance);
                var pulseColor = TimeService.GetActiveEvent() != null ? lastSegment.Color : "#ffffff";
                var textColor = TimeService.GetActiveEvent() != null ? lastSegment.Color : "#888888";
                var valueText = lastSegment.EndBalance >= 0
                    ? $"+{lastSegment.EndBalance.ToString("F2", CultureInfo.InvariantCulture)}h"
                    : $"{lastSegment.EndBalance.ToString("F2", CultureInfo.InvariantCulture)}h";

                <circle cx="@endX.ToString(CultureInfo.InvariantCulture)" cy="@endY.ToString(CultureInfo.InvariantCulture)" r="6" fill="@pulseColor" stroke="#333" stroke-width="2" class="pulse-circle" />
                @((MarkupString)$@"<text x=""{endX.ToString(CultureInfo.InvariantCulture)}"" y=""{(endY - 15).ToString(CultureInfo.InvariantCulture)}"" text-anchor=""middle"" fill=""{System.Net.WebUtility.HtmlEncode(textColor)}"" font-size=""14"" font-weight=""bold"">{System.Net.WebUtility.HtmlEncode(valueText)}</text>")
            }
            else
            {
                <!-- Show "no data" message but keep the grid -->
                @((MarkupString)$@"<text x=""400"" y=""200"" text-anchor=""middle"" fill=""#666"" font-size=""16"">{System.Net.WebUtility.HtmlEncode(Localizer["NoDataPeriod"].Value)}</text>")
            }
        </svg>
    </div>

    <!-- Budgets List -->
    <div class="budgets-section">
        <h3 class="section-title">@Localizer["ActivitiesAndBudgets"]</h3>
        <div class="budgets-list">
            @foreach (var activity in TimeService.Account.Activities.OrderBy(a => a.DisplayOrder))
            {
                var tracked = GetTrackedTimeForActivity(activity.Name);
                var budget = GetBudgetForActivity(activity.Id);
                var hasBudget = budget != null && budget.AllocatedTimeSpan.TotalSeconds > 0;
                var progress = hasBudget
                    ? Math.Min(100, (tracked.TotalHours / budget!.AllocatedTimeSpan.TotalHours) * 100)
                    : 0;
                var isOver = progress >= 100;

                <div class="budget-item" style="@GetBudgetItemStyle(activity.Color)">
                    <div class="budget-item-header">
                        <span class="budget-activity-name">
                            <span class="activity-color-dot small" style="@GetColorDotStyle(activity.Color)"></span>
                            @activity.Emoji @activity.Name
                        </span>
                        <span class="budget-time @(isOver ? "over" : "")">
                            @tracked.TotalHours.ToString("F1")h
                            @if (hasBudget)
                            {
                                <span class="budget-of"> / @budget!.AllocatedTimeSpan.TotalHours.ToString("F0")h</span>
                            }
                        </span>
                    </div>
                    @if (hasBudget)
                    {
                        <div class="budget-progress-track">
                            <div class="budget-progress-fill @(isOver ? "over" : "")" style="@GetBudgetProgressStyle(activity.Color, progress, isOver)"></div>
                        </div>
                    }
                    <button class="budget-edit-btn" @onclick="() => EditBudget(activity.Id)">@Localizer["SetBudget"]</button>
                </div>
            }
        </div>
    </div>
</div>

@if (IsEditingBudget)
{
    <div class="modal-overlay" @onclick="CancelEdit">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <h3>@string.Format(Localizer["BudgetFor"], EditingActivityName)</h3>
            <p>@(CurrentView == ViewMode.Day ? Localizer["HoursForToday"].Value : CurrentView == ViewMode.Week ? Localizer["HoursForThisWeek"].Value : Localizer["HoursForThisMonth"].Value)</p>
            <div class="edit-form">
                <div class="edit-field">
                    <label class="edit-label">@Localizer["AllocatedHours"]</label>
                    <input type="number" class="edit-input" @bind="EditingBudgetHours" min="0" step="1" />
                </div>
            </div>
            <div class="modal-actions">
                <button class="btn-cancel" @onclick="CancelEdit">@Localizer["Cancel"]</button>
                <button class="btn-save" @onclick="SaveBudget">@Localizer["Save"]</button>
            </div>
        </div>
    </div>
}


@code {
    private enum ViewMode { Day, Week, Month }
    private ViewMode CurrentView = ViewMode.Day;
    private List<ActivityBudget> _currentBudgets = new();
    private bool IsEditingBudget = false;
    private Guid EditingActivityId;
    private string EditingActivityName = "";
    private double EditingBudgetHours = 0;

    protected override async Task OnInitializedAsync()
    {
        TimeService.OnStateChanged += StateHasChanged;
        RefreshTimelineData();
        await LoadBudgetsAsync();
        
        // Refresh every 5 seconds
        _timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                RefreshTimelineData();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task LoadBudgetsAsync()
    {
        var dStart = DateOnly.FromDateTime(StartDate.DateTime);
        var dEnd = DateOnly.FromDateTime(EndDate.AddDays(-1).DateTime);
        
        _currentBudgets.Clear();
        foreach (var act in TimeService.Account.Activities)
        {
            var b = await StatisticsService.GetBudgetForPeriodAsync(act.Id, dStart, dEnd);
            if (b != null) _currentBudgets.Add(b);
        }
    }
    
    private void SetView(ViewMode mode)
    {
        CurrentView = mode;
        _ = LoadBudgetsAsync();
        RefreshTimelineData();
    }

    private DateTimeOffset StartDate => CurrentView switch
    {
        ViewMode.Day => new DateTimeOffset(DateTimeOffset.UtcNow.Date, TimeSpan.Zero),
        ViewMode.Week => DateTimeOffset.UtcNow.AddDays(-(int)DateTimeOffset.UtcNow.DayOfWeek + 1).Date, // Monday of this week
        _ => new DateTimeOffset(DateTimeOffset.UtcNow.Year, DateTimeOffset.UtcNow.Month, 1, 0, 0, 0, TimeSpan.Zero)
    };
        
    private DateTimeOffset EndDate => CurrentView switch
    {
        ViewMode.Day => StartDate.AddDays(1),
        ViewMode.Week => StartDate.AddDays(7),
        _ => StartDate.AddMonths(1)
    };

    private string PeriodLabel => CurrentView switch
    {
        ViewMode.Day => Localizer["Today"].Value,
        ViewMode.Week => Localizer["ThisWeek"].Value,
        _ => Localizer["ThisMonth"].Value
    };

    private TimeSpan TotalTime
    {
        get
        {
            var events = TimeService.Account.Events
                .Where(e => (e.StartTime >= StartDate && e.StartTime < EndDate) || 
                            (e.EndTime.HasValue && e.EndTime >= StartDate && e.EndTime < EndDate) ||
                            (e.StartTime < StartDate && (!e.EndTime.HasValue || e.EndTime > EndDate)))
                .ToList();

            double totalHours = 0;
            foreach (var e in events)
            {
                var start = e.StartTime > StartDate ? e.StartTime : StartDate;
                var end = (e.EndTime ?? DateTimeOffset.UtcNow) < EndDate ? (e.EndTime ?? DateTimeOffset.UtcNow) : EndDate;
                if (end > start)
                {
                    totalHours += (end - start).TotalHours;
                }
            }
            return TimeSpan.FromHours(totalHours);
        }
    }

    private TimeSpan GetTrackedTimeForActivity(string activityName)
    {
        var events = TimeService.Account.Events
            .Where(e => e.ActivityName == activityName &&
                        ((e.StartTime >= StartDate && e.StartTime < EndDate) || 
                        (e.EndTime.HasValue && e.EndTime >= StartDate && e.EndTime < EndDate) ||
                        (e.StartTime < StartDate && (!e.EndTime.HasValue || e.EndTime > EndDate))))
            .ToList();

        double totalHours = 0;
        foreach (var e in events)
        {
            var start = e.StartTime > StartDate ? e.StartTime : StartDate;
            var end = (e.EndTime ?? DateTimeOffset.UtcNow) < EndDate ? (e.EndTime ?? DateTimeOffset.UtcNow) : EndDate;
            if (end > start)
            {
                totalHours += (end - start).TotalHours;
            }
        }
        return TimeSpan.FromHours(totalHours);
    }

    private ActivityBudget? GetBudgetForActivity(Guid activityId)
    {
        return _currentBudgets.FirstOrDefault(b => b.ActivityId == activityId);
    }

    private void EditBudget(Guid activityId)
    {
        var activity = TimeService.Account.Activities.FirstOrDefault(a => a.Id == activityId);
        if (activity == null) return;
        
        EditingActivityId = activityId;
        EditingActivityName = activity.Name;
        var budget = GetBudgetForActivity(activityId);
        EditingBudgetHours = budget?.AllocatedTimeSpan.TotalHours ?? 0;
        IsEditingBudget = true;
    }

    private async Task SaveBudget()
    {
        var dStart = DateOnly.FromDateTime(StartDate.DateTime);
        var dEnd = DateOnly.FromDateTime(EndDate.AddDays(-1).DateTime);
        
        var budget = GetBudgetForActivity(EditingActivityId) ?? new ActivityBudget 
        { 
            ActivityId = EditingActivityId,
            StartDate = dStart,
            EndDate = dEnd
        };
        
        budget.AllocatedTimeSpan = TimeSpan.FromHours(EditingBudgetHours);
        budget.Type = CurrentView switch
        {
            ViewMode.Day => BudgetType.Daily,
            ViewMode.Week => BudgetType.Weekly,
            _ => BudgetType.Monthly
        };

        await StatisticsService.SaveBudgetAsync(budget);
        
        IsEditingBudget = false;
        await LoadBudgetsAsync();
    }

    private void CancelEdit()
    {
        IsEditingBudget = false;
    }

    public void Dispose()
    {
        TimeService.OnStateChanged -= StateHasChanged;
        _timer?.Dispose();
    }

    // --- Timeline Chart Logic ---
    private List<TimelineSegment> Segments { get; set; } = new();
    
    private double MinY => Segments.Count > 0 ? Math.Min(0, Math.Min(Segments.Min(s => s.StartBalance), Segments.Min(s => s.EndBalance))) : 0;
    private double MaxY => Segments.Count > 0 ? Math.Max(0, Math.Max(Segments.Max(s => s.StartBalance), Segments.Max(s => s.EndBalance))) : 1;
    private System.Threading.Timer? _timer;

    private void RefreshTimelineData()
    {
        var period = EndDate - StartDate;
        Segments = TimeService.GetTimelineData(period);
    }

    private double GetXFromTimestamp(DateTimeOffset timestamp)
    {
        var totalTicks = (EndDate - StartDate).Ticks;
        if (totalTicks == 0) return 400;
        
        var positionTicks = (timestamp - StartDate).Ticks;
        var ratio = (double)positionTicks / totalTicks;
        
        // Clamp to chart bounds [0, 1]
        ratio = Math.Clamp(ratio, 0.0, 1.0);
        
        // Map to chart X coordinates (50 to 750)
        return 50 + ratio * 700;
    }

    private double GetY(double value)
    {
        var range = MaxY - MinY;
        if (range == 0) range = 1;
        var normalized = (MaxY - value) / range;
        return 50 + normalized * 300;
    }



    private string FormatTimeLabel(DateTime time)
    {
        var period = EndDate - StartDate;
        if (period.TotalHours <= 24)
        {
            return time.ToString("HH:mm");
        }
        else
        {
            return time.ToString("dd MMM");
        }
    }

    private static string GetBudgetItemStyle(string color)
    {
        var normalized = Activity.SanitizeColor(color);
        return $"border-color: {ToRgba(normalized, 0.24)};";
    }

    private static string GetBudgetProgressStyle(string color, double progress, bool isOver)
    {
        var normalized = isOver ? "#EF4444" : Activity.SanitizeColor(color);
        return $"width: {progress.ToString(CultureInfo.InvariantCulture)}%; background: {normalized};";
    }

    private static string GetColorDotStyle(string color)
    {
        var normalized = Activity.SanitizeColor(color);
        return $"background: {normalized}; box-shadow: 0 0 0 4px {ToRgba(normalized, 0.16)};";
    }

    private static string ToRgba(string color, double alpha)
    {
        var normalized = Activity.SanitizeColor(color);
        var red = Convert.ToInt32(normalized.Substring(1, 2), 16);
        var green = Convert.ToInt32(normalized.Substring(3, 2), 16);
        var blue = Convert.ToInt32(normalized.Substring(5, 2), 16);
        return $"rgba({red}, {green}, {blue}, {alpha.ToString(CultureInfo.InvariantCulture)})";
    }
}
