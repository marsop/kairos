@using Kairos.Application.Resources
@using Kairos.Application.Services
@inject IStringLocalizer<Strings> Localizer
@inject ISyncConflictNotifier Notifier
@implements IDisposable

@if (_isVisible)
{
    <div class="modal-overlay" @onclick="() => Respond(false)">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <h3>@Localizer["SyncConflictTitle"]</h3>
            <p>@Localizer["SyncConflictMessage1"]</p>
            <p>@Localizer["SyncConflictMessage2"]</p>
            <div class="modal-actions">
                <button class="btn-cancel" @onclick="() => Respond(false)">@Localizer["KeepLocalData"]</button>
                <button class="btn-save" @onclick="() => Respond(true)">@Localizer["UseServerData"]</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _isVisible;
    private Action<bool>? _resolveCallback;

    protected override void OnInitialized()
    {
        Notifier.OnConflictDetected += HandleConflict;
    }

    private void HandleConflict(Action<bool> callback)
    {
        _resolveCallback = callback;
        _isVisible = true;
        InvokeAsync(StateHasChanged);
    }

    private void Respond(bool useServer)
    {
        _isVisible = false;
        _resolveCallback?.Invoke(useServer);
        _resolveCallback = null;
    }

    public void Dispose()
    {
        Notifier.OnConflictDetected -= HandleConflict;
    }
}
