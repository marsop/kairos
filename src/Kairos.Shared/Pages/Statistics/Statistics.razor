@page "/"
@page "/statistics"
@using Kairos.Shared.Services
@using Kairos.Shared.Resources
@using System.Globalization
@inject ITimeTrackingService TimeService
@inject IStatisticsService StatisticsService
@inject IStringLocalizer<Strings> Localizer

<div class="statistics-page">
    <h2 class="page-title">@Localizer["NavStatistics"]</h2>

    <div class="period-selector">
        <button class="period-button @(CurrentView == ViewMode.Week ? "selected" : "")" @onclick="() => SetView(ViewMode.Week)">This Week</button>
        <button class="period-button @(CurrentView == ViewMode.Month ? "selected" : "")" @onclick="() => SetView(ViewMode.Month)">This Month</button>
    </div>

    <div class="stat-summary-card">
        <div class="stat-label">Total Tracked Time</div>
        <div class="stat-big-value">@((int)TotalTime.TotalHours)<span class="stat-unit">h</span> @(TotalTime.Minutes)<span class="stat-unit">m</span></div>
        <div class="stat-period">@PeriodLabel</div>
    </div>

    <!-- Budgets List -->
    <div class="budgets-section">
        <h3 class="section-title">Activities &amp; Budgets</h3>
        <div class="budgets-list">
            @foreach (var activity in TimeService.Account.Activities.OrderBy(a => a.DisplayOrder))
            {
                var tracked = GetTrackedTimeForActivity(activity.Name);
                var budget = GetBudgetForActivity(activity.Id);
                var hasBudget = budget != null && budget.AllocatedTimeSpan.TotalSeconds > 0;
                var progress = hasBudget
                    ? Math.Min(100, (tracked.TotalHours / budget!.AllocatedTimeSpan.TotalHours) * 100)
                    : 0;
                var isOver = progress >= 100;

                <div class="budget-item">
                    <div class="budget-item-header">
                        <span class="budget-activity-name">@activity.Name</span>
                        <span class="budget-time @(isOver ? "over" : "")">
                            @tracked.TotalHours.ToString("F1")h
                            @if (hasBudget)
                            {
                                <span class="budget-of"> / @budget!.AllocatedTimeSpan.TotalHours.ToString("F0")h</span>
                            }
                        </span>
                    </div>
                    @if (hasBudget)
                    {
                        <div class="budget-progress-track">
                            <div class="budget-progress-fill @(isOver ? "over" : "")" style="width: @progress.ToString(CultureInfo.InvariantCulture)%"></div>
                        </div>
                    }
                    <button class="budget-edit-btn" @onclick="() => EditBudget(activity.Id)">Set budget</button>
                </div>
            }
        </div>
    </div>

    <!-- Timeline Chart -->
    <div class="chart-container">
        @((MarkupString)RenderChart())
    </div>
</div>

@if (IsEditingBudget)
{
    <div class="modal-overlay" @onclick="CancelEdit">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <h3>Budget for @EditingActivityName</h3>
            <p>Hours for @(CurrentView == ViewMode.Week ? "this week" : "this month")</p>
            <div class="edit-form">
                <div class="edit-field">
                    <label class="edit-label">Allocated hours</label>
                    <input type="number" class="edit-input" @bind="EditingBudgetHours" min="0" step="1" />
                </div>
            </div>
            <div class="modal-actions">
                <button class="btn-cancel" @onclick="CancelEdit">Cancel</button>
                <button class="btn-save" @onclick="SaveBudget">Save</button>
            </div>
        </div>
    </div>
}


@code {
    private enum ViewMode { Week, Month }
    private ViewMode CurrentView = ViewMode.Month;
    private List<ActivityBudget> _currentBudgets = new();
    private bool IsEditingBudget = false;
    private Guid EditingActivityId;
    private string EditingActivityName = "";
    private double EditingBudgetHours = 0;

    protected override async Task OnInitializedAsync()
    {
        TimeService.OnStateChanged += StateHasChanged;
        RefreshTimelineData();
        await LoadBudgetsAsync();
        
        // Refresh every 5 seconds
        _timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                RefreshTimelineData();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task LoadBudgetsAsync()
    {
        var dStart = DateOnly.FromDateTime(StartDate.DateTime);
        var dEnd = DateOnly.FromDateTime(EndDate.AddDays(-1).DateTime);
        
        _currentBudgets.Clear();
        foreach (var act in TimeService.Account.Activities)
        {
            var b = await StatisticsService.GetBudgetForPeriodAsync(act.Id, dStart, dEnd);
            if (b != null) _currentBudgets.Add(b);
        }
    }
    
    private void SetView(ViewMode mode)
    {
        CurrentView = mode;
        _ = LoadBudgetsAsync();
        RefreshTimelineData();
    }

    private DateTimeOffset StartDate => CurrentView == ViewMode.Week 
        ? DateTimeOffset.UtcNow.AddDays(-(int)DateTimeOffset.UtcNow.DayOfWeek + 1).Date // Monday of this week
        : new DateTimeOffset(DateTimeOffset.UtcNow.Year, DateTimeOffset.UtcNow.Month, 1, 0, 0, 0, TimeSpan.Zero);
        
    private DateTimeOffset EndDate => CurrentView == ViewMode.Week
        ? StartDate.AddDays(7)
        : StartDate.AddMonths(1);

    private string PeriodLabel => CurrentView == ViewMode.Week ? "This Week" : "This Month";

    private TimeSpan TotalTime
    {
        get
        {
            var events = TimeService.Account.Events
                .Where(e => (e.StartTime >= StartDate && e.StartTime < EndDate) || 
                            (e.EndTime.HasValue && e.EndTime >= StartDate && e.EndTime < EndDate) ||
                            (e.StartTime < StartDate && (!e.EndTime.HasValue || e.EndTime > EndDate)))
                .ToList();

            double totalHours = 0;
            foreach (var e in events)
            {
                var start = e.StartTime > StartDate ? e.StartTime : StartDate;
                var end = (e.EndTime ?? DateTimeOffset.UtcNow) < EndDate ? (e.EndTime ?? DateTimeOffset.UtcNow) : EndDate;
                if (end > start)
                {
                    totalHours += (end - start).TotalHours * e.Factor;
                }
            }
            return TimeSpan.FromHours(totalHours);
        }
    }

    private TimeSpan GetTrackedTimeForActivity(string activityName)
    {
        var events = TimeService.Account.Events
            .Where(e => e.ActivityName == activityName &&
                        ((e.StartTime >= StartDate && e.StartTime < EndDate) || 
                        (e.EndTime.HasValue && e.EndTime >= StartDate && e.EndTime < EndDate) ||
                        (e.StartTime < StartDate && (!e.EndTime.HasValue || e.EndTime > EndDate))))
            .ToList();

        double totalHours = 0;
        foreach (var e in events)
        {
            var start = e.StartTime > StartDate ? e.StartTime : StartDate;
            var end = (e.EndTime ?? DateTimeOffset.UtcNow) < EndDate ? (e.EndTime ?? DateTimeOffset.UtcNow) : EndDate;
            if (end > start)
            {
                totalHours += (end - start).TotalHours * e.Factor;
            }
        }
        return TimeSpan.FromHours(totalHours);
    }

    private ActivityBudget? GetBudgetForActivity(Guid activityId)
    {
        return _currentBudgets.FirstOrDefault(b => b.ActivityId == activityId);
    }

    private void EditBudget(Guid activityId)
    {
        var activity = TimeService.Account.Activities.FirstOrDefault(a => a.Id == activityId);
        if (activity == null) return;
        
        EditingActivityId = activityId;
        EditingActivityName = activity.Name;
        var budget = GetBudgetForActivity(activityId);
        EditingBudgetHours = budget?.AllocatedTimeSpan.TotalHours ?? 0;
        IsEditingBudget = true;
    }

    private async Task SaveBudget()
    {
        var dStart = DateOnly.FromDateTime(StartDate.DateTime);
        var dEnd = DateOnly.FromDateTime(EndDate.AddDays(-1).DateTime);
        
        var budget = GetBudgetForActivity(EditingActivityId) ?? new ActivityBudget 
        { 
            ActivityId = EditingActivityId,
            StartDate = dStart,
            EndDate = dEnd
        };
        
        budget.AllocatedTimeSpan = TimeSpan.FromHours(EditingBudgetHours);
        await StatisticsService.SaveBudgetAsync(budget);
        
        IsEditingBudget = false;
        await LoadBudgetsAsync();
    }

    private void CancelEdit()
    {
        IsEditingBudget = false;
    }

    public void Dispose()
    {
        TimeService.OnStateChanged -= StateHasChanged;
        _timer?.Dispose();
    }

    // --- Timeline Chart Logic ---
    private List<TimelineDataPoint> DataPoints { get; set; } = new();
    
    private double MinY => DataPoints.Count > 0 ? Math.Min(0, DataPoints.Min(p => p.BalanceHours)) : 0;
    private double MaxY => DataPoints.Count > 0 ? Math.Max(0, DataPoints.Max(p => p.BalanceHours)) : 1;
    private string GradientColor => DataPoints.LastOrDefault()?.BalanceHours >= 0 ? "#10b981" : "#ef4444";
    private System.Threading.Timer? _timer;

    private void RefreshTimelineData()
    {
        var period = EndDate - StartDate;
        DataPoints = TimeService.GetTimelineData(period);
    }

    private double GetXFromTimestamp(DateTimeOffset timestamp)
    {
        var totalTicks = (EndDate - StartDate).Ticks;
        if (totalTicks == 0) return 400;
        
        var positionTicks = (timestamp - StartDate).Ticks;
        var ratio = (double)positionTicks / totalTicks;
        
        // Clamp to chart bounds [0, 1]
        ratio = Math.Clamp(ratio, 0.0, 1.0);
        
        // Map to chart X coordinates (50 to 750)
        return 50 + ratio * 700;
    }

    private double GetY(double value)
    {
        var range = MaxY - MinY;
        if (range == 0) range = 1;
        var normalized = (MaxY - value) / range;
        return 50 + normalized * 300;
    }

    private string LinePath
    {
        get
        {
            if (DataPoints.Count < 2) return "";
            var sb = new System.Text.StringBuilder();
            sb.Append(FormattableString.Invariant($"M {GetXFromTimestamp(DataPoints[0].Timestamp)} {GetY(DataPoints[0].BalanceHours)}"));
            for (int i = 1; i < DataPoints.Count; i++)
            {
                sb.Append(FormattableString.Invariant($" L {GetXFromTimestamp(DataPoints[i].Timestamp)} {GetY(DataPoints[i].BalanceHours)}"));
            }
            return sb.ToString();
        }
    }

    private string AreaPath
    {
        get
        {
            if (DataPoints.Count < 2) return "";
            var sb = new System.Text.StringBuilder();
            var firstX = GetXFromTimestamp(DataPoints[0].Timestamp);
            var lastX = GetXFromTimestamp(DataPoints[^1].Timestamp);
            sb.Append(FormattableString.Invariant($"M {firstX} {GetY(0)}"));
            sb.Append(FormattableString.Invariant($" L {firstX} {GetY(DataPoints[0].BalanceHours)}"));
            for (int i = 1; i < DataPoints.Count; i++)
            {
                sb.Append(FormattableString.Invariant($" L {GetXFromTimestamp(DataPoints[i].Timestamp)} {GetY(DataPoints[i].BalanceHours)}"));
            }
            sb.Append(FormattableString.Invariant($" L {lastX} {GetY(0)}"));
            sb.Append(" Z");
            return sb.ToString();
        }
    }

    private string RenderChart()
    {
        var sb = new System.Text.StringBuilder();
        sb.Append(@"<svg viewBox=""0 0 800 400"" class=""timeline-chart"" preserveAspectRatio=""xMidYMid meet"">");
        
        // Always show grid lines
        sb.Append(@"<g class=""grid-lines"">");
        for (int i = 0; i <= 4; i++)
        {
            var y = 50 + i * 75;
            sb.Append(FormattableString.Invariant($@"<line x1=""50"" y1=""{y}"" x2=""750"" y2=""{y}"" stroke=""#333"" stroke-dasharray=""4,4"" />"));
        }
        // Vertical grid lines
        for (int i = 0; i <= 4; i++)
        {
            var x = 50 + i * 175;
            sb.Append(FormattableString.Invariant($@"<line x1=""{x}"" y1=""50"" x2=""{x}"" y2=""350"" stroke=""#333"" stroke-dasharray=""4,4"" />"));
        }
        sb.Append("</g>");
        
        // Always show Y-axis labels
        sb.Append(@"<g class=""y-labels"">");
        var range = MaxY - MinY;
        if (range == 0) range = 1;
        for (int i = 0; i <= 4; i++)
        {
            var value = MaxY - (i * range / 4);
            var y = 50 + i * 75;
            sb.Append(FormattableString.Invariant($@"<text x=""45"" y=""{y + 5}"" text-anchor=""end"" fill=""#888"" font-size=""12"">{value:F1}h</text>"));
        }
        sb.Append("</g>");
        
        // Always show X-axis time labels
        sb.Append(@"<g class=""x-labels"">");
        var chartEndTime = EndDate.DateTime;
        var chartStartTime = StartDate.DateTime;
        var chartPeriod = chartEndTime - chartStartTime;
        for (int i = 0; i <= 4; i++)
        {
            var x = 50 + i * 175; // 700 / 4 = 175
            var time = chartStartTime + TimeSpan.FromTicks((long)(chartPeriod.Ticks * i / 4.0));
            var timeLabel = FormatTimeLabel(time);
            sb.Append(FormattableString.Invariant($@"<text x=""{x}"" y=""370"" text-anchor=""middle"" fill=""#888"" font-size=""11"">{timeLabel}</text>"));
        }
        sb.Append("</g>");
        
        // Gradient definitions (always needed)
        sb.Append($@"<defs>
            <linearGradient id=""areaGradient"" x1=""0"" x2=""0"" y1=""0"" y2=""1"">
                <stop offset=""0%"" stop-color=""{GradientColor}"" stop-opacity=""0.4"" />
                <stop offset=""100%"" stop-color=""{GradientColor}"" stop-opacity=""0"" />
            </linearGradient>
            <linearGradient id=""lineGradient"" x1=""0"" x2=""1"" y1=""0"" y2=""0"">
                <stop offset=""0%"" stop-color=""{GradientColor}"" />
                <stop offset=""100%"" stop-color=""{GradientColor}"" />
            </linearGradient>
        </defs>");
        
        // Data visualization (only when we have data)
        if (DataPoints.Count > 1)
        {
            // Area fill
            sb.Append($@"<path d=""{AreaPath}"" fill=""url(#areaGradient)"" opacity=""0.3"" />");
            
            // Line
            sb.Append($@"<path d=""{LinePath}"" fill=""none"" stroke=""url(#lineGradient)"" stroke-width=""3"" />");
            
            // Current value indicator
            if (DataPoints.Count > 0)
            {
                var lastPoint = DataPoints.Last();
                var x = GetXFromTimestamp(lastPoint.Timestamp);
                var y = GetY(lastPoint.BalanceHours);
                var valueText = lastPoint.BalanceHours >= 0 
                    ? FormattableString.Invariant($"+{lastPoint.BalanceHours:F2}h") 
                    : FormattableString.Invariant($"{lastPoint.BalanceHours:F2}h");
                sb.Append(FormattableString.Invariant($@"<circle cx=""{x}"" cy=""{y}"" r=""6"" fill=""{GradientColor}"" class=""pulse-circle"" />"));
                sb.Append(FormattableString.Invariant($@"<text x=""{x}"" y=""{y - 15}"" text-anchor=""middle"" fill=""{GradientColor}"" font-size=""14"" font-weight=""bold"">{valueText}</text>"));
            }
        }
        else
        {
            // Show "no data" message but keep the grid
            sb.Append($@"<text x=""400"" y=""200"" text-anchor=""middle"" fill=""#666"" font-size=""16"">{Localizer["NoDataPeriod"]}</text>");
        }
        
        sb.Append("</svg>");
        return sb.ToString();
    }

    private string FormatTimeLabel(DateTime time)
    {
        var period = EndDate - StartDate;
        if (period.TotalHours <= 24)
        {
            return time.ToString("HH:mm");
        }
        else
        {
            return time.ToString("dd MMM");
        }
    }
}
